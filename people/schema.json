{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://planet-writelog/people/schema.json",
  "title": "Person",
  "type": "object",
  "required": ["name", "handle", "mvp", "title", "bio", "feeds"],
  "additionalProperties": false,
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "handle": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Lowercase alphanumeric + hyphens; must match filename"
    },
    "pronouns": { "type": "string" },
    "title": { "type": "string", "minLength": 1 },
    "bio": { "type": "string", "minLength": 1, "maxLength": 300 },
    "avatar": { "type": "string", "format": "uri" },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "website": { "type": "string", "format": "uri" },
        "bluesky": { "type": "string" },
        "facebook": { "type": "string" },
        "github": { "type": "string" },
        "linkedin": { "type": "string" },
        "mastodon": { "type": "string" },
        "twitter": { "type": "string" },
        "youtube": { "type": "string" }
      }
    },
    "feeds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["type", "url"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "blog" },
              "url": { "type": "string", "format": "uri" }
            }
          },
          {
            "type": "object",
            "required": ["type", "repo"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "github-releases" },
              "repo": {
                "type": "string",
                "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
              }
            }
          },
          {
            "type": "object",
            "required": ["type", "channel_id"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "youtube" },
              "channel_id": { "type": "string", "pattern": "^UC[A-Za-z0-9_-]+$" }
            }
          }
        ]
      }
    }
  }
}
