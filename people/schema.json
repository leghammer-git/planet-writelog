{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://planet-writelog/people/schema.json",
  "title": "Person",
  "type": "object",
  "required": ["name", "handle", "title", "bio", "feeds"],
  "additionalProperties": false,
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "handle": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Lowercase alphanumeric + hyphens; must match filename"
    },
    "pronouns": { "type": "string" },
    "title": { "type": "string", "minLength": 1 },
    "mvp": {
      "type": "object",
      "required": ["status", "category"],
      "additionalProperties": false,
      "properties": {
        "status":   { "type": "string", "enum": ["active", "former"] },
        "category": { "type": "string", "minLength": 1 }
      }
    },
    "bio": { "type": "string", "minLength": 0, "maxLength": 300 },
    "avatar": { "type": "string", "format": "uri" },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "website": { "type": "string", "format": "uri" },
        "bluesky": { "type": "string" },
        "facebook": { "type": "string" },
        "github": { "type": "string" },
        "linkedin": { "type": "string" },
        "mastodon": { "type": "string" },
        "twitter": { "type": "string" },
        "youtube": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" }, "minItems": 1 }
          ]
        }
      }
    },
    "feeds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["type", "url"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "blog" },
              "url": { "type": "string", "format": "uri" },
              "author": { "type": "string", "minLength": 1 },
              "label": { "type": "string", "minLength": 1 }
            }
          },
          {
            "type": "object",
            "required": ["type", "repo"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "github-releases" },
              "repo": {
                "type": "string",
                "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
              },
              "label": { "type": "string", "minLength": 1 }
            }
          },
          {
            "type": "object",
            "required": ["type"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "youtube" },
              "channel_id": { "type": "string", "pattern": "^UC[A-Za-z0-9_-]+$" },
              "channel": { "type": "string", "pattern": "^@[\\w-]+$" },
              "label": { "type": "string", "minLength": 1 }
            },
            "oneOf": [
              { "required": ["channel_id"] },
              { "required": ["channel"] }
            ]
          },
          {
            "type": "object",
            "required": ["type", "username"],
            "additionalProperties": false,
            "properties": {
              "type": { "const": "github-user" },
              "username": {
                "type": "string",
                "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]*[A-Za-z0-9])?$"
              },
              "label": { "type": "string", "minLength": 1 }
            }
          }
        ]
      }
    }
  }
}
