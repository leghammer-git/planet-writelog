---
layout: base.njk
pagination:
  data: people
  size: 1
  alias: person
permalink: /people/{{ person.handle }}/
eleventyComputed:
  title: "{{ person.name }}"
---
<section class="profile">
  <div class="profile__header">
    <img
      class="profile__avatar"
      src="{{ person.avatar or ('https://github.com/' + (person.links.github or person.handle) + '.png?size=120') }}"
      alt="{{ person.name }}"
      width="120"
      height="120"
    >
    <div class="profile__meta">
      <h1 class="profile__name">{{ person.name }}</h1>
      <p class="profile__title">{{ person.title }}</p>
      {% if person.mvp %}
        <span class="mvp-badge mvp-badge--{{ person.mvp.status }} mvp-badge--full">
          <svg class="mvp-badge__icon" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 1 2 3.5v4c0 3.5 2.5 6.3 6 7.5 3.5-1.2 6-4 6-7.5v-4Z"/></svg>Microsoft MVP · {{ person.mvp.category }}{% if person.mvp.status == 'former' %} · Former{% endif %}
        </span>
      {% endif %}
      {% if person.pronouns %}
        <span class="profile__pronouns">{{ person.pronouns }}</span>
      {% endif %}
      <p class="profile__bio">{{ person.bio }}</p>

      <ul class="profile__links">
        {% if person.links.website %}
          <li><a href="{{ person.links.website }}" rel="noopener noreferrer" target="_blank">Website</a></li>
        {% endif %}
        {% if person.links.bluesky %}
          <li><a href="https://bsky.app/profile/{{ person.links.bluesky }}" rel="noopener noreferrer" target="_blank">Bluesky</a></li>
        {% endif %}
        {% if person.links.facebook %}
          <li><a href="https://facebook.com/{{ person.links.facebook }}" rel="noopener noreferrer" target="_blank">Facebook</a></li>
        {% endif %}
        {% if person.links.github %}
          <li><a href="https://github.com/{{ person.links.github }}" rel="noopener noreferrer" target="_blank">GitHub</a></li>
        {% endif %}
        {% if person.links.linkedin %}
          <li><a href="https://linkedin.com/in/{{ person.links.linkedin }}" rel="noopener noreferrer" target="_blank">LinkedIn</a></li>
        {% endif %}
        {% if person.links.mastodon %}
          <li><a href="{{ person.links.mastodon }}" rel="noopener noreferrer" target="_blank">Mastodon</a></li>
        {% endif %}
        {% if person.links.twitter %}
          <li><a href="https://x.com/{{ person.links.twitter }}" rel="noopener noreferrer" target="_blank">Twitter</a></li>
        {% endif %}
        {% if person.links.youtube %}
          {% if person.links.youtube is string %}
            <li><a href="https://youtube.com/{{ person.links.youtube }}" rel="noopener noreferrer" target="_blank">YouTube</a></li>
          {% else %}
            {% for channel in person.links.youtube %}
              <li><a href="https://youtube.com/{{ channel }}" rel="noopener noreferrer" target="_blank">YouTube ({{ channel }})</a></li>
            {% endfor %}
          {% endif %}
        {% endif %}
      </ul>
    </div>
  </div>
</section>

<section class="person-feed">
  <h2>Posts from {{ person.name }}</h2>
  {%- set personItems = items | where("person_handle", person.handle) -%}
  {% if personItems.length %}
    <div class="feed-grid">
      {% for item in personItems %}
        {% include "item-card.njk" %}
      {% endfor %}
    </div>
  {% else %}
    <p class="feed-empty">No items yet for this person.</p>
  {% endif %}
</section>
