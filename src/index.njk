---
layout: base.njk
title: Feed
---
<section class="feed-header">
  <h1 class="feed-header__title">Community Feed</h1>
  <p class="feed-header__sub">Field notes for the admin who does it all</p>

  <div class="filter-bar" role="group" aria-label="Filter items">
    <div class="filter-group" data-filter-group="type">
      <span class="filter-label">Type</span>
      <button class="pill pill--active-blog" data-value="blog">Blog</button>
      <button class="pill" data-value="github-releases">Releases</button>
      <button class="pill pill--active-youtube" data-value="youtube">Videos</button>
    </div>
    <div class="filter-group">
      <span class="filter-label" id="person-picker-label">Person</span>
      <div class="person-picker" id="person-picker" aria-labelledby="person-picker-label">
        <button class="person-picker__trigger" aria-haspopup="listbox" aria-expanded="false" aria-controls="person-picker-list">Everyone</button>
        <ul class="person-picker__list" id="person-picker-list" role="listbox" aria-labelledby="person-picker-label" hidden>
          <li class="person-picker__option" data-value="all" role="option" aria-selected="true">
            <span class="person-picker__name">Everyone</span>
          </li>
          {% for person in people %}
          <li class="person-picker__option" data-value="{{ person.handle }}" role="option" aria-selected="false">
            <span class="person-picker__name">{{ person.name }}</span>
            <span class="person-picker__dots" aria-hidden="true">{% if person.feeds | where("type", "blog") | length %}<span class="type-dot type-dot--blog"></span>{% endif %}{% if (person.feeds | where("type", "github-releases") | length) or (person.feeds | where("type", "github-user") | length) %}<span class="type-dot type-dot--releases"></span>{% endif %}{% if person.feeds | where("type", "youtube") | length %}<span class="type-dot type-dot--youtube"></span>{% endif %}</span>
          </li>
          {% endfor %}
        </ul>
      </div>
    </div>
    <div class="filter-group">
      <label class="filter-label" for="keyword-input">Search</label>
      <input class="filter-input" id="keyword-input" type="search" placeholder="Filter by keyword…" autocomplete="off">
    </div>
  </div>
</section>

<section id="feed-results" class="feed-grid" aria-live="polite" aria-label="Feed items">
  {% if items.length %}
    {% for item in items %}
      {% set item = item %}
      {% include "item-card.njk" %}
    {% endfor %}
  {% else %}
    <p class="feed-empty">No items yet — run <code>npm run aggregate</code> to fetch content.</p>
  {% endif %}
</section>

<div class="load-more-wrap">
  <button class="load-more-btn" id="load-more" hidden>Load more</button>
</div>

<p class="feed-count" aria-live="polite">
  Showing <span id="visible-count">{{ items.length }}</span> of <span id="total-count">{{ items.length }}</span> items
</p>
